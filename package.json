{
	"name": "symlink",
	"private": true,
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"simple-git-hooks"
		]
	},
	"scripts": {
		"dev:web": "pnpm --filter @symlink/web dev",
		"dev:desktop": "pnpm --filter @symlink/desktop dev",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"prepare": "simple-git-hooks"
	},
	"simple-git-hooks": {
		"pre-commit": "pnpm check",
		"pre-push": "pnpm check"
	},
	"packageManager": "pnpm@10.30.2+sha512.36cdc707e7b7940a988c9c1ecf88d084f8514b5c3f085f53a2e244c2921d3b2545bc20dd4ebe1fc245feec463bb298aecea7a63ed1f7680b877dc6379d8d0cb4",
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"simple-git-hooks": "^2.13.1"
	}
}
