{
	"$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
	"productName": "Symlink",
	"version": "0.0.0",
	"identifier": "com.symlink.app",
	"build": {
		"frontendDist": "../dist",
		"devUrl": "http://localhost:1420",
		"beforeDevCommand": "pnpm dev",
		"beforeBuildCommand": "pnpm build"
	},
	"app": {
		"title": "Symlink",
		"windows": [
			{
				"label": "main",
				"width": 1024,
				"height": 768
			}
		],
		"security": {
			"csp": null
		}
	}
}
